// BuildingSync — Prisma schema reconciled with the live Supabase DB
// (project dbhmfvqvluqnhepujdyz). The DB was originally provisioned by
// the R&D project (super-octo-rotary-phone) with a wider schema; this
// file models only the tables Website-Beta R1 actually uses, preserving
// the live column names (e.g. WorkOrder.issue, Lease.leaseStartDate).
//
// R&D-only tables that exist on the database but aren't modeled here:
//   GuestVisit, VendorAccess, Notification, NotificationSetting,
//   NotificationTemplate, Integration, SystemConfig, License, AiUsage,
//   Session, MFACode, Permission, Device, Telemetry, Alert, governance_*,
//   owner_banks, vendor_*, marketplace_listings, organizations
//   (snake_case dup), users (dup), audit_log (dup), user_roles,
//   user_profiles, invites.
// Amenity/AmenityRule/AmenityBooking/Event/Post/Delivery were added in
// the v2 resident-design migration and are modeled below.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums (matching live DB) ─────────────────────────────────────

enum UserRole {
  admin
  facility_manager
  building_manager
  building_owner
  property_manager
  resident
  tenant
  concierge
  staff
  security
  vendor
  guest
}

enum BuildingType {
  commercial
  residential
  mixed
  industrial
}

enum WorkOrderStatus {
  open
  in_progress
  scheduled
  completed
  closed
}

enum WorkOrderPriority {
  urgent
  high
  normal
  low
}

enum SlaPolicy {
  urgent_4h
  high_24h
  normal_72h
  low_7d
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

enum AmenityApprovalPolicy {
  auto_approve
  manager_approval
}

enum IncidentType {
  security
  safety
  noise
  damage
  other
}

enum IncidentSeverity {
  low
  medium
  high
  urgent
}

enum IncidentStatus {
  open
  in_progress
  resolved
}

enum AnnouncementAudience {
  all
  tenants_only
  specific_units
}

// ─── Models ───────────────────────────────────────────────────────

// Mirror of Supabase auth.users keyed by the same uuid (auth.uid()).
// `password` is nullable since Supabase Auth owns credentials —
// the column survives from the R&D legacy and may hold legacy hashes
// for the seeded demo accounts.
model User {
  id              String    @id
  email           String    @unique
  name            String?
  password        String?
  role            UserRole
  // accessRoles UserRole[] — DB column exists (nullable array) but Prisma
  // can't represent a nullable scalar-array, so we leave it unmodeled.
  company         String?
  buildingId      String?
  unitId          String?
  unit            String?   // Free-form unit label (R&D legacy; prefer the FK)
  avatar          String?
  phone           String?
  isActive        Boolean   @default(true)
  isOrgAdmin      Boolean   @default(false)
  isBillingOwner  Boolean   @default(false)
  notifyEmail     Boolean   @default(true)
  notifySms       Boolean   @default(false)
  notifyInApp     Boolean   @default(true)
  // Jurisdiction the user signed up under (ISO 3166-2 subdivision
  // code, e.g. "CA-ON"). Drives /legal page defaults, currency/date
  // formatting, applicable notice templates. Captured at signup;
  // editable in /dashboard/account.
  region          String?
  // Address bits captured at signup. For residents/tenants these
  // typically match their building. For Building Managers they're
  // the management company's registered address. Used for postal-
  // code-to-region validation + building address cross-check.
  postalCode      String?
  city            String?
  // Approximate lat/lng from the signup location picker (reverse-
  // geocoded). Used for "verify on map" UX, not for routing.
  latitude        Float?
  longitude       Float?
  // BM-only verification fields. Surfaced in /platform/verifications
  // so the platform admin can confirm against the Ontario Business
  // Registry (OBR) and CMRAO licensee database before flipping
  // verifiedAt to allow the BM into /team.
  // - managerType: self_managed | incorporated | management_firm | cmrao_licensed
  // - businessNumber: federal 9-digit BN, optional program suffix
  //   (e.g. "123456789RC0001"). Verifiable at corporations.ic.gc.ca.
  // - licenseNumber: CMRAO licence for Ontario condo managers
  //   (mandatory under the CMSA, 2015). Verifiable at cmrao.ca.
  managerType     String?
  businessNumber  String?
  licenseNumber   String?
  // Recurring verification cache. The authoritative history lives in
  // ManagerVerification[]; these are denormalised for fast banner +
  // requireTeam checks (avoids a join on every page load).
  // - lastVerifiedAt — most recent successful admin review
  // - nextVerificationDue — earliest of: lastVerifiedAt + 365 days,
  //   licenseExpiresAt - 60 days, insuranceExpiresAt - 60 days
  lastVerifiedAt        DateTime?
  nextVerificationDue   DateTime?
  // Set when admin verifies a building_manager signup. Other roles are
  // auto-verified — gate only applies to BM. Null = pending review.
  verifiedAt      DateTime?
  lastLoginAt     DateTime?
  archivedAt      DateTime?
  archiveReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  building          Building?        @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  unitRel           Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  leases            Lease[]
  workOrdersOpened  WorkOrder[]      @relation("WorkOrderOpener")
  workOrdersAssign  WorkOrder[]      @relation("WorkOrderAssignee")
  workOrderNotes    WorkOrderNote[]  @relation("WorkOrderNoteAuthor")
  announcementsBy   Announcement[]   @relation("AnnouncementAuthor")
  documentsBy       Document[]       @relation("DocumentUploader")
  incidentsReported Incident[]       @relation("IncidentReporter")
  auditLogs         AuditLog[]       @relation("AuditActor")
  verifications     ManagerVerification[] @relation("ManagerVerificationTarget")
  verificationsRun  ManagerVerification[] @relation("ManagerVerificationReviewer")
  amenityBookings   AmenityBooking[]
  eventsCreated     Event[]          @relation("EventCreator")
  posts             Post[]           @relation("PostAuthor")
  deliveriesIn      Delivery[]       @relation("DeliveryRecipient")
  deliveriesLogged  Delivery[]       @relation("DeliveryLogger")
  pushSubscriptions PushSubscription[]

  @@index([buildingId])
  @@index([role])
  @@index([unitId])
  @@index([archivedAt])
  @@index([verifiedAt])
}

model Building {
  id             String        @id
  name           String
  address        String
  city           String
  state          String
  zipCode        String
  country        String
  latitude       Float?
  longitude      Float?
  type           BuildingType
  totalUnits     Int?
  totalArea      Float?
  yearBuilt      Int?
  description    String?
  imageUrl       String?
  // amenities String[] — DB column exists (nullable array); unmodeled.
  timezone       String
  isActive       Boolean       @default(true)
  enabledModules Json?
  inviteCode     String?       @unique
  inviteCodeUpdatedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  users         User[]
  units         Unit[]
  leases        Lease[]
  workOrders    WorkOrder[]
  announcements Announcement[]
  documents     Document[]
  incidents     Incident[]
  auditLogs     AuditLog[]
  amenities     Amenity[]
  events        Event[]
  posts         Post[]
  deliveries    Delivery[]
  license       License?
  notices       Notice[]
  aiUsage       AiUsage[]
}

model Unit {
  id              String   @id
  buildingId      String
  unitNumber      String
  floor           Int?
  wing            String?
  unitType        String?
  squareFeet      Float?
  bedrooms        Int?
  bathrooms       Float?
  // amenities String[] — DB column exists (nullable array); unmodeled.
  currentTenant   String?
  occupancyStatus String   @default("vacant")
  rentAmount      Float?
  leaseEndDate    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  users    User[]
  leases   Lease[]

  @@unique([buildingId, unitNumber])
}

model Lease {
  id                String    @id
  buildingId        String
  unitId            String
  tenantId          String
  leaseStartDate    DateTime
  leaseEndDate      DateTime
  rentAmountMonthly Float
  securityDeposit   Float?
  leaseType         String
  status            String
  notes             String?
  archivedAt        DateTime?
  archiveReason     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant   User     @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([unitId])
  @@index([buildingId])
}

model WorkOrder {
  id           String            @id
  buildingId   String
  unit         String            // Free-form unit label (R&D legacy; not an FK)
  issue        String            // Title / short description (legacy column name)
  description  String?           // Long-form details (added by Website-Beta)
  priority     WorkOrderPriority
  status       WorkOrderStatus   @default(open)
  openedById   String?           // Resident who submitted (added by Website-Beta)
  assigneeId   String?           // Staff member working on it
  vendorId     String?           // External vendor reference (R&D feature; not modeled here)
  slaPolicy    SlaPolicy
  slaDeadline  DateTime
  submittedAt  DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  openedBy   User?    @relation("WorkOrderOpener",   fields: [openedById], references: [id], onDelete: SetNull)
  assignee   User?    @relation("WorkOrderAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  notes      WorkOrderNote[]

  @@index([buildingId, status])
  @@index([assigneeId])
  @@index([openedById])
}

// Threaded notes on a work order. BM/FM/concierge in the same building
// can post; resident sees them via /dashboard/maintenance (read-only).
// Append-only — no edit, no delete in R1.
model WorkOrderNote {
  id          String   @id @default(cuid())
  workOrderId String
  authorId    String
  body        String
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  author    User      @relation("WorkOrderNoteAuthor", fields: [authorId], references: [id])

  @@index([workOrderId, createdAt])
  @@index([authorId])
}

model Payment {
  id         String    @id
  buildingId String?
  userId     String?
  amount     Float
  currency   String    @default("USD")
  status     String
  method     String?
  stripeId   String?
  metadata   Json?
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
}

// CASL/PIPEDA-grade announcement broadcast. Soft-delete via deletedAt
// so an audit trail is preserved.
model Announcement {
  id            String               @id @default(cuid())
  buildingId    String
  authorId      String
  title         String
  body          String
  // Audience targeting added in PR5. "all" goes to every resident+tenant
  // in the building. "tenants_only" filters residents out (useful for
  // rent / lease comms). "specific_units" uses targetUnitIds.
  audience      AnnouncementAudience @default(all)
  targetUnitIds String[]             @default([])
  createdAt     DateTime             @default(now())
  deletedAt     DateTime?

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  author   User     @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  @@index([buildingId, createdAt(sort: Desc)])
  @@index([deletedAt])
  @@index([audience])
  @@index([authorId])
}

// Building-scoped document library. Files live in Supabase Storage; this
// table is metadata. Soft-deleted via deletedAt so RTA / LTB evidence
// trails are preserved even after a BM removes a document from view.
model Document {
  id            String    @id @default(cuid())
  buildingId    String
  title         String
  description   String?
  storagePath   String    // e.g. "documents/{buildingId}/{id}/{filename}"
  mimeType      String
  sizeBytes     Int
  category      String    @default("other") // bylaws | fire_safety | lease | vendor | insurance | maintenance | other
  visibility    String    @default("staff_only") // public | staff_only
  uploadedById  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([buildingId, visibility, deletedAt])
  @@index([uploadedById])
  @@index([createdAt(sort: Desc)])
}

// Building incidents (security, safety, noise, damage). Reported by
// concierge/BM/FM, viewed and resolved by BM/FM. Different lifecycle
// from WorkOrder — incidents track an *event*, not a maintenance task.
model Incident {
  id             String           @id @default(cuid())
  buildingId     String
  reportedById   String
  type           IncidentType
  severity       IncidentSeverity @default(medium)
  status         IncidentStatus   @default(open)
  title          String
  description    String?
  location       String?
  resolvedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  building   Building @relation(fields: [buildingId],   references: [id], onDelete: Cascade)
  reportedBy User     @relation("IncidentReporter", fields: [reportedById], references: [id])

  @@index([buildingId, status])
  @@index([buildingId, createdAt(sort: Desc)])
  @@index([reportedById])
}

// Append-only audit trail. Matches the live DB shape (userId/resource/
// resourceId/changes/status). Don't UPDATE or DELETE these rows —
// they're evidence-grade for LTB landlord-tenant disputes.
model AuditLog {
  id           String   @id
  userId       String?
  userEmail    String?
  buildingId   String?
  action       String
  resource     String
  resourceId   String?
  changes      Json?
  ipAddress    String?
  userAgent    String?
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  actor    User?     @relation("AuditActor",   fields: [userId],     references: [id], onDelete: SetNull)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  @@index([resource, resourceId])
  @@index([userId, createdAt])
  @@index([buildingId, createdAt])
  @@index([createdAt])
}

// ─── v2 resident-design tables ──────────────────────────────────────
// Added in the v2_resident_amenities_events_posts_deliveries migration.
// Amenity/AmenityRule/AmenityBooking are ported from R&D; Event/Post/
// Delivery are designed for Website-Beta.

model Amenity {
  id                        String                @id
  buildingId                String
  name                      String
  category                  String
  description               String?
  isActive                  Boolean               @default(true)
  bookingRequired           Boolean               @default(false)
  capacity                  Int?
  imageUrl                  String?
  openTime                  String                @default("09:00")
  closeTime                 String                @default("21:00")
  slotDurationMinutes       Int                   @default(60)
  advanceNoticeHours        Int                   @default(0)
  cleanupBufferMinutes      Int                   @default(0)
  maxBookingDurationMinutes Int?
  approvalPolicy            AmenityApprovalPolicy @default(auto_approve)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  building Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  rules    AmenityRule[]
  bookings AmenityBooking[]

  @@index([buildingId])
}

model AmenityRule {
  id        String   @id
  amenityId String
  text      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@index([amenityId])
}

model AmenityBooking {
  id        String        @id
  amenityId String
  userId    String
  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(confirmed)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([amenityId, startTime])
  @@index([userId])
}

model Event {
  id          String    @id
  buildingId  String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  location    String?
  imageUrl    String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  building  Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([buildingId, startTime])
}

model Post {
  id         String    @id
  buildingId String
  authorId   String
  title      String
  body       String
  category   String    @default("general")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  author   User     @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([buildingId, createdAt(sort: Desc)])
  @@index([deletedAt])
}

model Delivery {
  id              String    @id
  buildingId      String
  recipientUserId String
  loggedById      String?
  sender          String
  description     String?
  pickupCode      String
  status          String    @default("pending")
  notes           String?
  receivedAt      DateTime  @default(now())
  pickedUpAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  building  Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  recipient User     @relation("DeliveryRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  loggedBy  User?    @relation("DeliveryLogger", fields: [loggedById], references: [id], onDelete: SetNull)

  @@index([buildingId, status])
  @@index([recipientUserId, status])
}

// Per-building enterprise license. SaaS customers get a row managed
// by the platform; on-prem customers paste a signed key. Validation
// + heartbeat live in lib/license.ts.
// Recurring verification history for Building Managers. Authoritative
// record of every admin review — initial verification at signup AND
// subsequent annual / license-driven re-reviews.
//
// Why a separate model (not just User fields):
//   • Audit trail — LTB / insurance / procurement reviewers need to
//     see WHO verified WHAT WHEN. Single mutable User row can't tell
//     that story.
//   • Snapshots — captures company / license / insurance state AT
//     the time of verification. If a BM later changes their company
//     name, we can still prove what was verified.
//   • Financial-management facts — RTA + CMSA require specific
//     financial controls (trust accounts, fidelity bonds, E&O
//     insurance). Captured here per-verification.
model ManagerVerification {
  id                  String   @id @default(cuid())
  userId              String
  reviewedById        String?
  reviewedAt          DateTime @default(now())
  // When the next re-verification is required. NULL = indefinite
  // (rare; reserved for grandfathered accounts).
  validUntil          DateTime?
  // approved | rejected | expired | pending_renewal
  status              String   @default("approved")
  notes               String?
  // Optional link to evidence stored in object storage (e.g. signed
  // articles of incorporation, CMRAO certificate scan).
  evidenceUrl         String?

  // Company snapshot at time of verification
  companyName         String
  managerType         String
  businessNumber      String?
  licenseNumber       String?  // CMRAO
  licenseExpiresAt    DateTime?

  // Financial-management facts — Ontario RTA + CMSA compliance.
  // Trust account = bank where rent / condo fees are held separate
  // from operating funds (statutory requirement). Insurance + bond
  // are CMRAO requirements for condo managers.
  trustAccountBank    String?
  insuranceCarrier    String?
  insurancePolicyNum  String?
  insuranceExpiresAt  DateTime?
  managesReserveFund  Boolean  @default(false)
  fidelityBondAmount  Float?

  createdAt           DateTime @default(now())

  user        User  @relation("ManagerVerificationTarget",   fields: [userId],       references: [id], onDelete: Cascade)
  reviewedBy  User? @relation("ManagerVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, reviewedAt])
  @@index([validUntil])
  @@index([status])
}

// On-prem appliance license records. Distinct from `License` (which is
// per-building SaaS licensing) — this one tracks per-appliance licenses
// issued to on-prem customers, with appliance fingerprint, last
// check-in, and revocation. The appliance POSTs to
// /api/onprem/license/verify on a 24h cadence; this row is the
// source of truth for what it gets back.
model OnpremLicense {
  id                  String    @id @default(uuid())
  // The opaque license string customers paste into their appliance's
  // .env. Format: bsk_live_<base32>. Index for fast lookup.
  licenseKey          String    @unique
  customerOrg         String
  contactEmail        String
  // Free-text — for admins to remember why this license exists.
  notes               String?
  // Hard cap on what features the appliance is allowed to run.
  // String[] for forward-compat with future features.
  features            String[]  @default([])
  maxBuildings        Int       @default(10)
  maxUnits            Int       @default(1000)
  // Set on issuance. After this date, verify returns valid=false.
  expiresAt           DateTime
  // Set when admin revokes mid-term (refund, contract terminated).
  // verify returns valid=false with reason="revoked".
  revokedAt           DateTime?
  revokedReason       String?
  // Per-appliance identity, set on first successful verify call.
  // Subsequent calls with a different fingerprint return
  // fingerprint_mismatch (defends against license-key sharing).
  applianceId         String?
  applianceFingerprint String?
  // Observability — what the appliance reported on last check-in.
  lastCheckedAt       DateTime?
  lastReportedVersion String?
  lastReportedIp      String?
  // Audit
  issuedById          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([customerOrg])
  @@index([expiresAt])
}

model License {
  id              String   @id
  buildingId      String?  @unique
  product         String   @default("BuildingSync SaaS")
  mode            String   @default("saas") // saas | on_prem
  plan            String   @default("essential")
  customer        String?
  seatLimit       Int?
  expiresAt       DateTime?
  capabilities    String[] @default([])
  aiEnabled       Boolean  @default(false)
  signedPayload   String?
  lastHeartbeatAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  building Building? @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
}

// Web Push subscription per user/device. Endpoint is the push service
// URL; p256dh + auth are the keys we encrypt payloads with. One row
// per browser/device combination — users on iPhone + laptop get two.
model PushSubscription {
  id           String    @id
  userId       String
  endpoint     String    @unique
  p256dh       String
  auth         String
  userAgent    String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Ontario RTA legal notices (N4 / N5 / N12 / N13 etc). One row per
// served notice; payload holds type-specific fields so adding new
// notice types doesn't require a migration. Status flow: draft →
// served → resolved | withdrawn.
model Notice {
  id             String    @id
  buildingId     String
  leaseId        String?
  tenantUserId   String?
  createdById    String
  type           String    // "N4" | "N5" | "N12" | ...
  status         String    @default("draft") // draft | served | resolved | withdrawn
  payload        Json
  servedAt       DateTime?
  servedMethod   String?   // in_person | mail | email | door
  remediationBy  DateTime? // e.g. N4 14-day pay-or-vacate deadline
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, status])
  @@index([leaseId])
  @@index([tenantUserId])
}

// Inbound contact / pilot-interest submissions from the public site
// (/contact). Persisted FIRST, then emailed — so a missing RESEND_API_KEY
// or a Resend outage can never silently drop a lead. The platform admin
// can review these even if no email arrived. `emailedAt` records whether
// the notification email actually went out; null = needs follow-up.
model ContactSubmission {
  id         String    @id
  name       String
  email      String
  topic      String    // pilot | enterprise | support | press | other
  message    String
  // Light triage / provenance metadata. No tracking cookies — just what
  // the request already carries.
  country    String?   // from CF-IPCountry / x-vercel-ip-country header
  userAgent  String?
  // Email-delivery outcome. Set when the notification email succeeds.
  emailedAt  DateTime?
  emailError String?   // last send error, if any (for ops follow-up)
  // Simple workflow so the team can mark leads handled.
  status     String    @default("new") // new | contacted | closed | spam
  createdAt  DateTime  @default(now())

  @@index([status, createdAt])
  @@index([email])
}

// Per-call AI usage ledger. One row per Claude request made on behalf of a
// building, recording the feature, model, token counts, and computed cost.
// This is BOTH the billing source for metered AI pricing AND an audit trail
// of AI-assisted decisions (e.g. policy drafting, work-order triage). Append
// only in spirit — we never edit a usage row after the fact.
//
// `feature` is a stable key (e.g. "work_order_triage", "draft_announcement",
// "policy_assist") so usage can be grouped per capability tier for billing.
// `costMicros` is the computed cost in millionths of a USD dollar (integer to
// avoid float drift); divide by 1_000_000 for dollars. Rates live in
// lib/ai-metering.ts and may change, so we snapshot the cost at call time.
model AiUsage {
  id              String   @id
  buildingId      String
  userId          String?  // who triggered it (null if system/cron)
  feature         String   // capability key, e.g. "work_order_triage"
  model           String   // e.g. "claude-sonnet-4-6"
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  cacheReadTokens Int      @default(0)
  cacheWriteTokens Int     @default(0)
  costMicros      Int      @default(0) // computed USD cost ×1e6
  createdAt       DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, createdAt])
  @@index([buildingId, feature])
}
