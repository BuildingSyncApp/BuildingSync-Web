# dependencies
/node_modules

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env
.env.local
.env.*.local
# Standalone .env-style files for one-off secrets (vapid keys, etc.).
# .env.example is intentionally tracked as the source-of-truth template.
*.env
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# prisma client output
/src/generated/prisma

# editor
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# test/build artifacts
/coverage
/test-results
build-*.txt
build-*.log

# claude memory dir is workspace-local, not for the repo
.claude/

# AI agent customization files (local only)
AGENTS.md
.github/instructions/
.github/agents/
.github/skills/

# package-lock kept untracked to mirror R&D convention
package-lock.json

# on-prem SKU lives in a separate private repo (BuildingSync-Onprem).
# Block any local onprem/ folder from being committed back into this
# (public-ish) repo by accident.
/onprem/
