# BuildingSync R1 — environment template
# Copy to .env.local for dev. Never commit a populated .env*.

# --- App ---
APP_BASE_URL=http://localhost:3000
ADMIN_HOST=admin.buildingsync.app

# --- Auth (own auth — argon2id + signed sessions, lib/auth-core) ---
# AUTH_SECRET signs the session cookie and one-shot action links
# (password reset, set-password invites). Must be >= 32 chars and kept
# secret. Generate with: openssl rand -base64 48
AUTH_SECRET=
# IMPERSONATION_SIGNING_SECRET signs admin "View as" tokens
# (lib/impersonation). Separate secret so rotating one doesn't drop the
# other. Generate with: openssl rand -base64 48
IMPERSONATION_SIGNING_SECRET=

# --- Object storage (Cloudflare R2, S3-compatible) ---
# Document file storage for app/team/documents (lib/storage.ts). Create a
# bucket + an R2 API token in the Cloudflare dashboard (R2 → Manage API
# Tokens). Free tier (10 GB + 1M writes/mo, zero egress) covers current
# scale. Safe to leave unset in dev if you don't exercise document
# upload/download.
#   R2_ACCOUNT_ID  = Cloudflare account id (the R2 endpoint subdomain)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=buildingsync-documents

# --- Database (Neon Postgres, ca-central-1) ---
# See docs/NEON-MIGRATION-RUNBOOK.md. Get both from Neon Console →
# Connection Details.
# DATABASE_URL = pooled (host contains -pooler) — runtime + Vercel
#   format: postgresql://USER:PW@HOST-pooler.ca-central-1.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL   = direct (no -pooler) — for `prisma migrate`
#   format: postgresql://USER:PW@HOST.ca-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
DIRECT_URL=

# --- Stripe --- Dashboard → Developers → API keys
# STRIPE_ENABLED gates the rent-payment flow. Leave unset (or "0")
# until Stripe merchant onboarding compliance review is approved.
# Flip to "1" once the account is live to enable the Pay button +
# /api/stripe/* routes.
STRIPE_ENABLED=0
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend --- resend.com/api-keys (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=BuildingSync <noreply@buildingsync.app>

# --- Enterprise license signing ---
# HMAC-SHA256 secret used to sign + verify enterprise license keys
# (lib/license.ts). Generate with: openssl rand -base64 48
LICENSE_SIGNING_SECRET=change-me-random-base64-string

# --- Booking + analytics (sales motion) ---
# Optional Calendly / Cal.com link embedded on /walkthrough. Leave
# unset and the page falls back to a mailto-only flow.
NEXT_PUBLIC_CALENDLY_URL=
# Optional Plausible analytics. Set to your apex domain to enable.
# Self-hosters can also override the script src below.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=

# --- Anthropic (AI assist) ---
# Used by /api/ai/draft-announcement for BM announcement drafting.
# Get a key from https://console.anthropic.com/. Server-only — never
# expose to the client. Sonnet 4.6 by default.
ANTHROPIC_API_KEY=sk-ant-...

# --- Web Push (VAPID) ---
# Generate with: node scripts/generate-vapid.mjs
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is shipped to the client and used to
# subscribe browsers; VAPID_PRIVATE_KEY signs outgoing push messages
# (server-only). VAPID_SUBJECT is a contact mailto: URL.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@buildingsync.app

# --- White-label / brand adaptation ---
# Override any of these on a per-deployment basis to ship the product
# under a customer's brand. Leave all unset for the canonical
# BuildingSync identity. Read by lib/brand.ts at module load.
# - NAME: display name used in the manifest, footer, and titles.
# - SHORT_NAME: narrow-surface variant (mobile manifest, tab title).
# - DESCRIPTION: PWA manifest description.
# - SUPPORT_EMAIL: contact address used in empty states and footer.
# - HOST: marketing host without protocol, used for absolute URLs.
# - THEME_COLOR: PWA background + theme colour (CSS hex).
# - SHOW_POWERED_BY: "true" to keep a small "Powered by BuildingSync"
#   line in the footer (co-branded tier); "false" for fully unbranded.
# - PARENT_ATTRIBUTION: footer line after the brand name. Set to
#   "none" to suppress it entirely.
NEXT_PUBLIC_BRAND_NAME=
NEXT_PUBLIC_BRAND_SHORT_NAME=
NEXT_PUBLIC_BRAND_DESCRIPTION=
NEXT_PUBLIC_BRAND_SUPPORT_EMAIL=
NEXT_PUBLIC_BRAND_HOST=
NEXT_PUBLIC_BRAND_THEME_COLOR=
NEXT_PUBLIC_BRAND_SHOW_POWERED_BY=
NEXT_PUBLIC_BRAND_PARENT_ATTRIBUTION=

# --- On-prem license signing ---
# Ed25519 keypair used to sign /api/onprem/license/verify responses.
# Generate with: node scripts/generate-onprem-keys.mjs
# The PUBLIC key also gets baked into each on-prem appliance image so
# the appliance can verify responses locally (defends against MITM).
# The PRIVATE key is server-only — never expose to client/embed in
# the appliance.
ONPREM_LICENSE_PRIVATE_KEY_B64=
ONPREM_LICENSE_PUBLIC_KEY_B64=

# --- Cron (Vercel-scheduled jobs) ---
# Shared secret the Vercel cron sends in an Authorization header so a
# random outsider can't trigger our scheduled jobs (e.g. the daily
# manager-verification expiry sweep). Generate with:
#   openssl rand -base64 32
CRON_SECRET=
