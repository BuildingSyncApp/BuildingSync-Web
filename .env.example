# BuildingSync R1 — environment template
# Copy to .env.local for dev. Never commit a populated .env*.

# --- App ---
APP_BASE_URL=http://localhost:3000
ADMIN_HOST=admin.buildingsync.app

# --- Supabase --- Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# --- Database --- Settings → Database → Connection string
# DATABASE_URL = pooled connection (port 6543, transaction mode) — for runtime + Vercel
#   format: postgresql://postgres.{ref}:{password}@aws-0-{region}.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL   = direct connection (port 5432) — for `prisma migrate`
#   format: postgresql://postgres:{password}@db.{ref}.supabase.co:5432/postgres
DATABASE_URL=
DIRECT_URL=

# --- Stripe --- Dashboard → Developers → API keys
# STRIPE_ENABLED gates the rent-payment flow. Leave unset (or "0")
# until Stripe merchant onboarding compliance review is approved.
# Flip to "1" once the account is live to enable the Pay button +
# /api/stripe/* routes.
STRIPE_ENABLED=0
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend --- resend.com/api-keys (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=BuildingSync <noreply@buildingsync.app>
